PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/koonji?retryWrites=true&w=majority
NODE_ENV=development

# Nodemailer (Gmail App Password recommended)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
ADMIN_EMAIL=admin@koonji.com

# Calendly
CALENDLY_URL=https://calendly.com/koonji

# Client URL for CORS
CLIENT_URL=http://localhost:5173
